{
  "name": "n8n-nodes-mcp-demand-engine",
  "version": "1.0.0",
  "description": "n8n node for MCP Demand Engine — LinkedIn signals, ICP scoring, enrichment, and CRM routing via n8n workflows.",
  "keywords": [
    "n8n",
    "n8n-node",
    "mcp",
    "demand-gen",
    "linkedin",
    "lead-generation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/developers-universe-1/agentic-demand-engine",
  "author": {
    "name": "developers-universe-1",
    "email": ""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/developers-universe-1/agentic-demand-engine.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/McpDemandEngineApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/McpDemandEngine/McpDemandEngine.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^7.15.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "n8n-workflow": "*",
    "prettier": "^3.3.2",
    "typescript": "^5.5.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
